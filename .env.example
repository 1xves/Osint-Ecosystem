# ─── OSINT System Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in values before running anything.
# .env is gitignored. Never commit real keys.

# ─── Supabase (PostgreSQL) ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Async connection pool via asyncpg (Transaction mode pooler — port 6543, NOT 5432)
# Project Settings → Database → Connection string → Transaction mode
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_strong_password

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Ollama (Local LLM Inference) ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_ESCALATION_MODEL=qwen3:22b
OLLAMA_EXTRACTION_MODEL=qwen3:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Data Source API Keys ──────────────────────────────────────────────────────
# Crunchbase — Basic plan ($29/mo) minimum. Get at: https://data.crunchbase.com
CRUNCHBASE_API_KEY=

# SerpAPI — Google Search results. Get at: https://serpapi.com
SERPAPI_API_KEY=

# OpenSecrets — Free non-commercial. Get at: https://www.opensecrets.org/api
OPENSECRETS_API_KEY=

# Proxycurl — LinkedIn data, $0.01/profile. Get at: https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# People Data Labs — Free credits on signup. Get at: https://www.peopledatalabs.com
PDL_API_KEY=

# MediaStack — Optional news source. Get at: https://mediastack.com
MEDIASTACK_API_KEY=

# ─── Free APIs (no key needed, but vars included for completeness) ─────────────
# SEC EDGAR: https://efts.sec.gov — no key, just respect 10 req/sec limit
# FEC: https://api.open.fec.gov — no key for basic, optional for higher limits
FEC_API_KEY=

# ProPublica: https://projects.propublica.org/api-docs/nonprofit-explorer — no key
# USASpending: https://api.usaspending.gov — no key
# CourtListener: https://www.courtlistener.com/api — free token after registration
COURTLISTENER_API_KEY=

# FollowTheMoney — state campaign finance (optional; unauthenticated allowed at lower rate)
# https://www.followthemoney.org/our-data/data-for-professionals/api/
FOLLOWTHEMONEY_API_KEY=

# OpenCorporates — business registration data (optional; unauthenticated fallback exists)
# https://api.opencorporates.com/documentation/API-Reference
OPENCORPORATES_API_KEY=

# ─── Research Pipeline ────────────────────────────────────────────────────────
RESEARCH_PIPELINE_URL=http://localhost:5050
RESEARCH_PIPELINE_API_KEY=

# ─── Budget Controls ──────────────────────────────────────────────────────────
# Hard stop on Proxycurl spend per run (USD)
PROXYCURL_BUDGET_PER_RUN_USD=25.00

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
# API key sent by frontend as X-API-Key header. Must also be embedded in static/index.html.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_key_here

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Absolute path on the HOST to the directory containing the tunnel credentials JSON.
# File inside must be named: 1ed096ee-50d9-4ad1-b9c8-255aeccd28a4.json
# Transfer with: scp ~/.cloudflared/<uuid>.json user@vps:/opt/osint/.cloudflared/
# See deploy/DEPLOYMENT.md Step 5 for full instructions.
CLOUDFLARED_CREDS_DIR=/opt/osint/.cloudflared
